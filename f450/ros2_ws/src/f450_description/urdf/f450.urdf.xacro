<?xml version="1.0"?>
<robot name="f450_simple" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========================= -->
  <!-- Parameters -->
  <!-- ========================= -->

  <!-- Tổng khối lượng drone, chỉnh theo drone thật sau -->
  <xacro:property name="mass" value="1.5"/>

  <!-- F450: khoảng cách chéo motor-motor khoảng 0.45 m -->
  <!-- arm_xy = 0.45 / (2*sqrt(2)) ≈ 0.159 -->
  <xacro:property name="arm_xy" value="0.159"/>

  <!-- Kích thước mô hình đơn giản -->
  <xacro:property name="body_size_x" value="0.18"/>
  <xacro:property name="body_size_y" value="0.18"/>
  <xacro:property name="body_size_z" value="0.04"/>

  <xacro:property name="arm_length" value="0.48"/>
  <xacro:property name="arm_width" value="0.035"/>
  <xacro:property name="arm_height" value="0.025"/>

  <xacro:property name="motor_radius" value="0.025"/>
  <xacro:property name="motor_height" value="0.025"/>

  <xacro:property name="prop_length" value="0.18"/>
  <xacro:property name="prop_width" value="0.025"/>
  <xacro:property name="prop_height" value="0.004"/>

  <!-- ========================= -->
  <!-- Materials -->
  <!-- ========================= -->

  <material name="black">
    <color rgba="0.02 0.02 0.02 1.0"/>
  </material>

  <material name="red">
    <color rgba="0.9 0.05 0.05 1.0"/>
  </material>

  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>

  <material name="gray">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>

  <!-- ========================= -->
  <!-- Physical propeller macro -->
  <!-- ========================= -->

  <xacro:macro name="physical_propeller" params="idx x y yaw mat">

    <link name="propeller_${idx}_link">

      <!-- Cánh số 1 -->
      <visual>
        <origin xyz="0 0 0" rpy="0 0 ${yaw}"/>
        <geometry>
          <box size="${prop_length} ${prop_width} ${prop_height}"/>
        </geometry>
        <material name="${mat}"/>
      </visual>

      <!-- Cánh số 2, vuông góc với cánh số 1 -->
      <visual>
        <origin xyz="0 0 0" rpy="0 0 ${yaw + 1.57079632679}"/>
        <geometry>
          <box size="${prop_length} ${prop_width} ${prop_height}"/>
        </geometry>
        <material name="${mat}"/>
      </visual>

      <!-- Inertia nhỏ cho propeller -->
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.012"/>
        <inertia
          ixx="0.000001"
          ixy="0.0"
          ixz="0.0"
          iyy="0.000032"
          iyz="0.0"
          izz="0.000032"/>
      </inertial>

    </link>

    <joint name="propeller_${idx}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="propeller_${idx}_link"/>
      <origin xyz="${x} ${y} 0.065" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.0001" friction="0.0"/>
    </joint>

  </xacro:macro>

  <!-- ========================= -->
  <!-- Base link: toàn bộ thân drone là 1 rigid body -->
  <!-- ========================= -->

  <link name="base_link">

    <!-- Thân giữa -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${body_size_x} ${body_size_y} ${body_size_z}"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${body_size_x} ${body_size_y} ${body_size_z}"/>
      </geometry>
    </collision>

    <!-- Tay drone đường chéo 1 -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0.785398"/>
      <geometry>
        <box size="${arm_length} ${arm_width} ${arm_height}"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0.785398"/>
      <geometry>
        <box size="${arm_length} ${arm_width} ${arm_height}"/>
      </geometry>
    </collision>

    <!-- Tay drone đường chéo 2 -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -0.785398"/>
      <geometry>
        <box size="${arm_length} ${arm_width} ${arm_height}"/>
      </geometry>
      <material name="white"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 -0.785398"/>
      <geometry>
        <box size="${arm_length} ${arm_width} ${arm_height}"/>
      </geometry>
    </collision>

    <!-- Motor 1: front left -->
    <visual>
      <origin xyz="${arm_xy} ${arm_xy} 0.02" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${motor_radius}" length="${motor_height}"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <!-- Motor 2: front right -->
    <visual>
      <origin xyz="${arm_xy} -${arm_xy} 0.02" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${motor_radius}" length="${motor_height}"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <!-- Motor 3: rear right -->
    <visual>
      <origin xyz="-${arm_xy} -${arm_xy} 0.02" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${motor_radius}" length="${motor_height}"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <!-- Motor 4: rear left -->
    <visual>
      <origin xyz="-${arm_xy} ${arm_xy} 0.02" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${motor_radius}" length="${motor_height}"/>
      </geometry>
      <material name="gray"/>
    </visual>


    <!-- ========================= -->
    <!-- Landing gear / càng đáp -->
    <!-- ========================= -->

    <!-- Skid trái -->
    <visual>
      <origin xyz="0 0.12 -0.17" rpy="0 0 0"/>
      <geometry>
        <box size="0.38 0.025 0.025"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 0.12 -0.17" rpy="0 0 0"/>
      <geometry>
        <box size="0.38 0.025 0.025"/>
      </geometry>
    </collision>

    <!-- Skid phải -->
    <visual>
      <origin xyz="0 -0.12 -0.17" rpy="0 0 0"/>
      <geometry>
        <box size="0.38 0.025 0.025"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 -0.12 -0.17" rpy="0 0 0"/>
      <geometry>
        <box size="0.38 0.025 0.025"/>
      </geometry>
    </collision>

    <!-- 4 thanh chống càng đáp -->
    <visual>
      <origin xyz="0.12 0.12 -0.095" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.018 0.15"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0.12 0.12 -0.095" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.018 0.15"/>
      </geometry>
    </collision>

    <visual>
      <origin xyz="-0.12 0.12 -0.095" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.018 0.15"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="-0.12 0.12 -0.095" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.018 0.15"/>
      </geometry>
    </collision>

    <visual>
      <origin xyz="0.12 -0.12 -0.095" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.018 0.15"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0.12 -0.12 -0.095" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.018 0.15"/>
      </geometry>
    </collision>

    <visual>
      <origin xyz="-0.12 -0.12 -0.095" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.018 0.15"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="-0.12 -0.12 -0.095" rpy="0 0 0"/>
      <geometry>
        <box size="0.018 0.018 0.15"/>
      </geometry>
    </collision>

    <!-- Inertial của toàn bộ drone -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia
        ixx="0.03" ixy="0.0" ixz="0.0"
        iyy="0.03" iyz="0.0"
        izz="0.06"/>
    </inertial>

  </link>

  <!-- ========================= -->
  <!-- Motor frames -->
  <!-- Các link này dùng làm vị trí apply force sau này -->
  <!-- ========================= -->

  <link name="motor_1_link"/>
  <link name="motor_2_link"/>
  <link name="motor_3_link"/>
  <link name="motor_4_link"/>

  <joint name="motor_1_joint" type="fixed">
    <parent link="base_link"/>
    <child link="motor_1_link"/>
    <origin xyz="${arm_xy} ${arm_xy} 0.04" rpy="0 0 0"/>
  </joint>

  <joint name="motor_2_joint" type="fixed">
    <parent link="base_link"/>
    <child link="motor_2_link"/>
    <origin xyz="${arm_xy} -${arm_xy} 0.04" rpy="0 0 0"/>
  </joint>

  <joint name="motor_3_joint" type="fixed">
    <parent link="base_link"/>
    <child link="motor_3_link"/>
    <origin xyz="-${arm_xy} -${arm_xy} 0.04" rpy="0 0 0"/>
  </joint>

  <joint name="motor_4_joint" type="fixed">
    <parent link="base_link"/>
    <child link="motor_4_link"/>
    <origin xyz="-${arm_xy} ${arm_xy} 0.04" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- Sensor frames -->
  <!-- ========================= -->

  <link name="imu_link"/>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

  <link name="camera_link"/>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.08 0 -0.03" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!-- 4 physical propellers -->
  <!-- ========================= -->

  <xacro:physical_propeller
    idx="1"
    x="${arm_xy}"
    y="${arm_xy}"
    yaw="0.785398"
    mat="red"/>

  <xacro:physical_propeller
    idx="2"
    x="${arm_xy}"
    y="-${arm_xy}"
    yaw="-0.785398"
    mat="white"/>

  <xacro:physical_propeller
    idx="3"
    x="-${arm_xy}"
    y="-${arm_xy}"
    yaw="0.785398"
    mat="red"/>

  <xacro:physical_propeller
    idx="4"
    x="-${arm_xy}"
    y="${arm_xy}"
    yaw="-0.785398"
    mat="white"/>

</robot>